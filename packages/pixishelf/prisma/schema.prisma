generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id                  Int                        @id @default(autoincrement())
  name                String
  username            String?
  userId              String? // pixiv 用户id
  bio                 String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  avatar              String?
  backgroundImg       String?
  isStarred           Boolean                    @default(false)
  artworks            Artwork[]
  localImportMappings LocalImportArtistMapping[]

  @@unique([username, userId], name: "unique_username_userid")
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([isStarred])
}

model LocalImportArtistMapping {
  id              Int      @id @default(autoincrement())
  artistDirectory String   @unique
  artistId        Int
  artist          Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([artistId])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Artwork {
  id                 Int             @id @default(autoincrement())
  title              String
  description        String?
  artistId           Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  descriptionLength  Int             @default(0)
  directoryCreatedAt DateTime?
  imageCount         Int             @default(0)
  bookmarkCount      Int?
  externalId         String?
  isAiGenerated      Boolean?
  originalUrl        String?
  size               String?
  sourceDate         DateTime?
  sourceUrl          String?
  thumbnailUrl       String?
  xRestrict          String?
  likeCount          Int             @default(0)
  metaSource         String?         @unique
  metadataFormat     String?
  pixivAiType        Int?
  pixivType          Int?
  sanityLevel        Int?
  storagePath        String?         @unique
  rawMetadata        ArtworkRawMetadata?
  artist             Artist?         @relation(fields: [artistId], references: [id])
  likes              ArtworkLike[]
  seriesId           Int?
  series             Series?         @relation(fields: [seriesId], references: [id])
  seriesArtworks     SeriesArtwork[]
  artworkTags        ArtworkTag[]
  images             Image[]
  source             ArtworkSource   @default(PIXIV_IMPORTED)

  @@unique([externalId])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([directoryCreatedAt])
  @@index([imageCount])
  @@index([sourceDate])
  @@index([artistId, sourceDate(sort: Desc), id(sort: Desc)], map: "Artwork_artistId_sourceDate_id_idx")
  @@index([externalId])
  @@index([likeCount])
  @@index([metaSource])
  @@index([metadataFormat])
}

model ArtworkRawMetadata {
  id              Int      @id @default(autoincrement())
  artworkId       Int      @unique
  rawMetadataJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  artwork         Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId])
}

model Tag {
  id            Int                      @id @default(autoincrement())
  name          String                   @unique
  isSystem      Boolean                  @default(false)
  systemKey     String?                  @unique
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  artworkCount  Int                      @default(0)
  description   String?
  name_zh       String?
  search_vector Unsupported("tsvector")?
  translateType TranslateType            @default(NONE)
  abstract      String?
  image         String?
  name_en       String?
  artworkTags   ArtworkTag[]

  @@index([name])
  @@index([name_zh]) // 增加索引，提高查询速度
  @@index([name_en]) //  增加索引，提高查询速度
  @@index([artworkCount], map: "Tag_artworkCount_idx")
  @@index([artworkCount(sort: Desc), name], map: "Tag_artworkCount_name_idx")
  // [新增] 告诉 Prisma 这个 GIN 索引是存在的
  // 注意：需要启用 previewFeatures = ["extendedIndexes"]
  @@index([search_vector], type: Gin)
}

model ArtworkTag {
  id        Int      @id @default(autoincrement())
  artworkId Int
  tagId     Int
  createdAt DateTime @default(now())
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([artworkId, tagId])
}

model Image {
  id                  Int                 @id @default(autoincrement())
  path                String
  width               Int?
  height              Int?
  size                Int?
  sortOrder           Int                 @default(0)
  artworkId           Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  webpAnimationStatus Int?                @db.SmallInt
  chaptersPath        String?
  chaptersCount       Int                 @default(0)
  chaptersDuration    Float?
  chaptersUpdatedAt   DateTime?
  chaptersHash        String?
  mediaType           MediaType           @default(UNKNOWN)
  artwork             Artwork?            @relation(fields: [artworkId], references: [id])
  videoMetadata       MediaVideoMetadata?

  @@unique([artworkId, path], name: "unique_artwork_path")
  @@index([webpAnimationStatus])
  @@index([chaptersPath])
  @@index([mediaType])
}

model MediaVideoMetadata {
  imageId        Int              @id
  image          Image            @relation(fields: [imageId], references: [id], onDelete: Cascade)
  probeStatus    MediaProbeStatus @default(PENDING)
  probeUpdatedAt DateTime?
  probeError     String?          @db.Text
  hasAudio       Boolean?
  audioCodec     String?
  audioChannels  Int?
  videoCodec     String?
  duration       Float?
  fps            Float?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([probeStatus])
  @@index([hasAudio])
}

model UserBA {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified Boolean?
  image         String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  likes    ArtworkLike[]
  settings UserSetting[]
}

model Account {
  id            String   @id @default(cuid())
  userId        String
  type          String?
  providerId    String
  accountId     String
  refresh_token String?  @db.Text
  access_token  String?  @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?  @db.Text
  session_state String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user UserBA @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      UserBA   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ArtworkLike {
  id        Int      @id @default(autoincrement())
  userId    String
  artworkId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  user      UserBA   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
  @@index([artworkId])
  @@index([userId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserSetting {
  id        Int      @id @default(autoincrement())
  userId    String
  key       String
  value     String?
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      UserBA   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model TriggerLog {
  id            Int      @id @default(autoincrement())
  operation     String   @db.VarChar(10)
  table_name    String   @db.VarChar(50)
  record_id     Int?
  old_value     Int?
  new_value     Int?
  error_message String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamp()

  @@index([created_at])
  @@index([operation])
  @@index([table_name, record_id])
  @@index([created_at], map: "idx_trigger_log_created_at")
  @@index([operation], map: "idx_trigger_log_operation")
  @@index([table_name, record_id], map: "idx_trigger_log_table_record")
}

enum TranslateType {
  NONE // 0-无
  PIXIV // 1-pixiv
  AI // 2-AI
  MANUAL // 3-人工标注
}

model SystemJob {
  id        String    @id @default(cuid())
  type      String    @db.VarChar(50)
  status    JobStatus @default(PENDING)
  progress  Int       @default(0)
  message   String?   @db.Text
  result    Json?
  error     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  scanRuns  ScanRun[]

  @@index([type, status])
  @@index([createdAt])
  @@map("system_jobs")
}

model ScanRun {
  id                String        @id @default(cuid())
  systemJobId       String?
  systemJob         SystemJob?    @relation(fields: [systemJobId], references: [id], onDelete: SetNull)
  type              ScanRunType
  mode              ScanRunMode
  status            ScanRunStatus @default(RUNNING)
  startedAt         DateTime      @default(now())
  finishedAt        DateTime?
  durationMs        Int?
  totalArtworks     Int           @default(0)
  processedArtworks Int           @default(0)
  succeededArtworks Int           @default(0)
  skippedArtworks   Int           @default(0)
  failedArtworks    Int           @default(0)
  newArtists        Int           @default(0)
  newTags           Int           @default(0)
  newImages         Int           @default(0)
  errorMessage      String?       @db.Text
  logRef            String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             ScanRunItem[]

  @@index([startedAt])
  @@index([status, startedAt])
  @@index([type, mode, startedAt])
  @@index([systemJobId])
  @@map("scan_runs")
}

model ScanRunItem {
  id                   String            @id @default(cuid())
  scanRunId            String
  scanRun              ScanRun           @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  externalId           String?
  title                String?
  artistName           String?
  relativeDirectory    String?           @db.Text
  metadataRelativePath String?           @db.Text
  status               ScanRunItemStatus
  action               ScanRunItemAction
  mediaCount           Int               @default(0)
  newImageCount        Int               @default(0)
  errorMessage         String?           @db.Text
  startedAt            DateTime          @default(now())
  finishedAt           DateTime?
  durationMs           Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([scanRunId, status])
  @@index([scanRunId, action])
  @@index([externalId])
  @@map("scan_run_items")
}

enum ScanRunType {
  PIXIV
  LOCAL_IMPORT
  LOCAL_CREATE
  BATCH_IMPORT
}

enum ScanRunMode {
  FULL
  INCREMENTAL
  CLIENT_LIST
  RESCAN
  LOCAL_RESCAN
  LOCAL_DIRECTORY_IMPORT
  LOCAL_CREATE
  BATCH_CREATE
  BATCH_REGISTER_IMAGES
}

enum ScanRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScanRunItemStatus {
  SUCCESS
  SKIPPED
  FAILED
}

enum ScanRunItemAction {
  CREATE
  UPDATE
  SKIP_EXISTING
  SKIP_INVALID_METADATA
  SKIP_NO_MEDIA
  FAILED_PARSE
  FAILED_COLLECT
  FAILED_WRITE
}

model ScheduledTask {
  id                String       @id @default(cuid())
  key               String       @unique @db.VarChar(80)
  type              String       @db.VarChar(50)
  enabled           Boolean      @default(false)
  scheduleMode      ScheduleMode @default(DAILY)
  time              String       @db.VarChar(5)
  timezone          String       @default("Asia/Shanghai") @db.VarChar(50)
  priority          Int          @default(100)
  mutexKey          String?      @db.VarChar(80)
  lastTriggeredAt   DateTime?
  lastTriggeredDate String?      @db.VarChar(10)
  lastJobId         String?
  config            Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([enabled, priority])
  @@index([type])
  @@index([mutexKey])
  @@map("scheduled_tasks")
}

enum ScheduleMode {
  DAILY
}

enum JobStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
  CANCELLING
}

enum MediaType {
  IMAGE
  VIDEO
  ANIMATION
  UNKNOWN
}

enum MediaProbeStatus {
  PENDING
  PROBING
  COMPLETED
  FAILED
  SKIPPED
}

model Series {
  id             Int             @id @default(autoincrement())
  title          String
  description    String?
  coverImageUrl  String?
  source         String          @default("LOCAL") // 用于区分数据来源，'LOCAL'是自己建的，'PIXIV'是导入的
  externalId     String? // 用于存原来的Pixiv 系列 ID，比如 '123456'
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  artworks       Artwork[]
  seriesArtworks SeriesArtwork[]

  // 这个索引让数据库知道：同一个来源下的同一个外部ID，只能有一条记录
  @@unique([source, externalId])
}

// 定义枚举
enum SeriesType {
  LOCAL // 本地创建
  PIXIV // Pixiv 导入
}

enum ArtworkSource {
  LOCAL_CREATED
  PIXIV_IMPORTED
  LOCAL_IMPORT
}

model SeriesArtwork {
  seriesId  Int
  artworkId Int
  sortOrder Int
  series    Series  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  artwork   Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([seriesId, artworkId])
  @@index([seriesId])
  @@index([artworkId])
}
