# PixiShelf local Next.js development environment
# Copy this file to .env.local when running packages/pixishelf directly with pnpm.

# Database running on the host machine or exposed from Docker Compose.
POSTGRES_USER=pixishelf
POSTGRES_PASSWORD=password
POSTGRES_DB=pixishelf
DATABASE_URL=postgresql://pixishelf:password@127.0.0.1:5432/pixishelf?connection_limit=20&pool_timeout=20

# Auth and admin bootstrap.
JWT_SECRET=your-very-secure-jwt-secret-key-here-at-least-32-characters
JWT_TTL=604800
BETTER_AUTH_SECRET=your-very-secure-jwt-secret-key-here-at-least-32-characters
BETTER_AUTH_URL=http://localhost:5430
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5430

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123
ADMIN_INIT_ENABLED=true
ADMIN_INIT_FORCE_RESET=false

# Local filesystem path used when Next.js runs outside Docker.
SCAN_PATH=D:\your\pixiv\data

# Local media services exposed by Docker Compose.
NEXT_PUBLIC_IMGPROXY_URL=http://127.0.0.1:5431
NEXT_PUBLIC_THUMBOR_VIDEO_URL=http://127.0.0.1:5433

# Internal and webhook tokens for local API testing.
INTERNAL_JOB_TOKEN=replace-with-a-long-random-token
SCAN_WEBHOOK_TOKEN=replace-with-a-long-random-token

# Remote scanner.
USE_REMOTE_SCANNER=false
REMOTE_SCANNER_URL=http://127.0.0.1:3000
