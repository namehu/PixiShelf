# PixiShelf 环境配置模板
# ===========================================
# 配置说明：复制此文件为 .env 并根据需要修改配置值
# ===========================================

# ===========================================
# Docker Compose 配置 (用于容器编排)
# ===========================================

# Docker 镜像配置
IMAGE_TAG=latest

# 宿主机端口
PIXISHELF_HOST_PORT=5430
POSTGRES_HOST_PORT=5432
IMGPROXY_HOST_PORT=5431
THUMBOR_HOST_PORT=5433
PRISMA_STUDIO_HOST_PORT=5555

# 宿主机图片目录。Windows 路径可使用 C:\Users\YourName\Pictures\pixiv
PIXISHELF_DATA_PATH=./data

# ===========================================
# 数据库配置
# ===========================================

# 数据库容器配置
POSTGRES_USER=pixishelf
POSTGRES_PASSWORD=password
POSTGRES_DB=pixishelf

# ===========================================
# 应用安全配置
# ===========================================

# JWT密钥 (生产环境必须修改，至少32字符)
JWT_SECRET=your-very-secure-jwt-secret-key-here-at-least-32-characters

# JWT过期时间 (秒)
JWT_TTL=604800
# 管理员账户
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123

# 管理员初始化配置
ADMIN_INIT_ENABLED=true
ADMIN_INIT_FORCE_RESET=false

# 内部计划任务接口 Token（生产环境必须修改为强随机值）
INTERNAL_JOB_TOKEN=replace-with-a-long-random-token

# 扫描 Webhook Token（用于 POST /api/webhooks/scan 的 Bearer Token 认证）
SCAN_WEBHOOK_TOKEN=replace-with-a-long-random-token

# scheduler 容器 tick 间隔秒数
SCHEDULER_TICK_SECONDS=60

# scheduler 调用的应用地址。
# 开发环境默认访问宿主机 pnpm dev；生产 docker-compose.deploy.yml 固定使用 http://app:5430。
PIXISHELF_INTERNAL_URL=http://host.docker.internal:5430

# ===========================================
# 服务器配置
# ===========================================

# 运行环境
NODE_ENV=production

# 图片扫描路径 (容器内路径，通常不需要修改)
SCAN_PATH=/app/data

# Better Auth 配置
BETTER_AUTH_SECRET=your-very-secure-jwt-secret-key-here-at-least-32-characters
BETTER_AUTH_URL=http://localhost:5430
# 允许额外来源访问，多个来源使用英文逗号分隔。
# 示例：BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.6.127:5430,https://pixi.example.com
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5430

# 浏览器访问图片代理和视频截帧服务的地址。
# 生产反代示例：
# NEXT_PUBLIC_IMGPROXY_URL=https://pixi.example.com/_image
# NEXT_PUBLIC_THUMBOR_VIDEO_URL=https://pixi.example.com/_video
NEXT_PUBLIC_IMGPROXY_URL=http://localhost:5431
NEXT_PUBLIC_THUMBOR_VIDEO_URL=http://localhost:5433
